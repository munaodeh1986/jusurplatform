    <script>
        // Language Toggle
        let isEnglish = false;

        function toggleLanguage() {
            isEnglish = !isEnglish;
            if (isEnglish) {
                document.body.classList.add('english');
            } else {
                document.body.classList.remove('english');
            }
        }

        // Modal Functions
        function openModal() {
            document.getElementById('joinModal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('joinModal').style.display = 'none';
        }

        // Problems Data
        const problems = [
            { id: 1, titleAr: "هدر الطعام في المقصف المدرسي", titleEn: "Food Waste in School Cafeteria", descAr: "كميات كبيرة من الطعام تُهدر يومياً في المقصف المدرسي", descEn: "Large amounts of food wasted daily in the school cafeteria", category: "env", badge: "بيئي", badgeEn: "Environmental", adopters: 45 },
            { id: 2, titleAr: "ضعف الوعي المالي لدى الطلاب", titleEn: "Poor Financial Literacy Among Students", descAr: "الطلاب لا يعرفون كيفية إدارة أموالهم بشكل صحيح", descEn: "Students don't know how to manage their money properly", category: "edu", badge: "تعليمي", badgeEn: "Educational", adopters: 32 },
            { id: 3, titleAr: "قلة الأنشطة الترفيهية في المدرسة", titleEn: "Lack of Recreational Activities", descAr: "عدم وجود أنشطة جاذبة للطلاب خلال الفسحة", descEn: "No engaging activities for students during break time", category: "health", badge: "اجتماعي", badgeEn: "Social", adopters: 28 },
            { id: 4, titleAr: "صعوبة متابعة الواجبات المدرسية", titleEn: "Difficulty Tracking Homework", descAr: "الطلاب ينسون الواجبات أو لا يعرفون مواعيد التسليم", descEn: "Students forget homework or don't know deadlines", category: "tech", badge: "تقني", badgeEn: "Tech", adopters: 67 },
            { id: 5, titleAr: "استهلاك المياه بشكل مفرط", titleEn: "Excessive Water Consumption", descAr: "هدر كبير في استهلاك المياه داخل المدرسة", descEn: "Large water waste inside the school", category: "env", badge: "بيئي", badgeEn: "Environmental", adopters: 23 },
            { id: 6, titleAr: "التنمر بين الطلاب", titleEn: "Bullying Among Students", descAr: "ظاهرة التنمر تؤثر على الصحة النفسية للطلاب", descEn: "Bullying affects students' mental health", category: "health", badge: "صحي", badgeEn: "Health", adopters: 89 }
        ];

        function filterProblems(category) {
            const filtered = category === 'all' ? problems : problems.filter(p => p.category === category);
            renderProblems(filtered);
            
            // Update active filter button
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
        }

        function renderProblems(problemsArray) {
            const grid = document.getElementById('problemsGrid');
            grid.innerHTML = problemsArray.map(problem => `
                <div class="problem-card">
                    <span class="problem-badge">${isEnglish ? problem.badgeEn : problem.badge}</span>
                    <h3 class="problem-title">${isEnglish ? problem.titleEn : problem.titleAr}</h3>
                    <p class="problem-desc">${isEnglish ? problem.descEn : problem.descAr}</p>
                    <div class="problem-stats">
                        <span><i class="fas fa-users"></i> ${problem.adopters} ${isEnglish ? 'adopters' : 'مهتم'}</span>
                        <button class="adopt-btn" onclick="openModal()">${isEnglish ? 'Adopt Problem' : 'تبنى المشكلة'}</button>
                    </div>
                </div>
            `).join('');
        }

        // Initial render
        renderProblems(problems);

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if(target) target.scrollIntoView({behavior: 'smooth'});
            });
        });

        // Close modal on click outside
        window.onclick = function(event) {
            const modal = document.getElementById('joinModal');
            if (event.target === modal) closeModal();
        }
    </script>
